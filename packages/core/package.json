{
  "name": "@loquix/core",
  "version": "0.2.0",
  "description": "Web Components for AI/LLM chat interfaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loquix-dev/loquix.git",
    "directory": "packages/core"
  },
  "homepage": "https://loquix.dev",
  "bugs": {
    "url": "https://github.com/loquix-dev/loquix/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define/*": {
      "types": "./dist/components/core/*.d.ts",
      "import": "./dist/components/core/*.js"
    },
    "./classes/*": {
      "types": "./dist/components/core/*.d.ts",
      "import": "./dist/components/core/*.js"
    },
    "./controllers/*": {
      "types": "./dist/controllers/*.d.ts",
      "import": "./dist/controllers/*.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./i18n/translations/*": {
      "types": "./dist/i18n/translations/*.d.ts",
      "import": "./dist/i18n/translations/*.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js"
    },
    "./tokens/variables.css": "./src/tokens/variables.css",
    "./tokens/themes/*": "./src/tokens/themes/*.css",
    "./custom-elements.json": "./custom-elements.json",
    "./cdn": "./cdn/loquix.min.js"
  },
  "sideEffects": [
    "./dist/components/core/define-*.js",
    "./dist/index.js"
  ],
  "files": [
    "dist",
    "cdn",
    "src/tokens",
    "custom-elements.json",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsc -b --force --emitDeclarationOnly && pnpm cem",
    "build:cdn": "vite build --config vite.config.cdn.ts",
    "test": "wtr",
    "test:coverage": "wtr --coverage",
    "test:watch": "wtr --watch",
    "cem": "cem analyze --litelement --globs \"src/components/**/*.ts\" --exclude \"**/*.test.ts\" --exclude \"**/*.styles.ts\""
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.0",
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-playwright": "^0.11.0",
    "lit": "^3.2.0",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "vite": "^6.4.2"
  },
  "customElements": "custom-elements.json"
}
